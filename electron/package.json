{
  "name": "djx",
  "version": "1.0.0",
  "description": "DJ Toolkit — Discover, analyze, and manage your music library",
  "author": "DJX",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.djx.app",
    "productName": "DJX",
    "mac": {
      "category": "public.app-category.music",
      "target": ["dmg"],
      "icon": "build/icon.icns"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend"
      },
      {
        "from": "../core",
        "to": "backend/core"
      },
      {
        "from": "../api",
        "to": "backend/api"
      },
      {
        "from": "../sc_discover.py",
        "to": "backend/sc_discover.py"
      },
      {
        "from": "../requirements.txt",
        "to": "backend/requirements.txt"
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}
